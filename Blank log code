                        return `<button class="keypad-btn w-full aspect-square rounded-2xl text-2xl font-semibold ${key === '⌫' ? 'text-purple-400' : 'text-gray-200'} bg-[#1a1a24] hover:bg-[#252530] transition-all" data-key="${key}">${key}</button>`;
                    }).join('')}
                </div>
                
                <div class="text-center mt-8">
                    <p class="text-xs text-gray-600">Standard PIN: <span class="text-purple-400 font-mono">1234</span></p>
                    <p class="text-xs text-gray-600 mt-1">Developer PIN: <span class="text-orange-400 font-mono">6741</span></p>
                </div>
            </div>
        </div>
    `;
    
    // Update PIN dots function
    function updateDots() {
        for (let i = 0; i < 4; i++) {
            const dot = document.getElementById(`pin-dot-${i}`);
            if (dot) {
                if (pinInput.length > i) {
                    dot.style.background = '#c084fc';
                    dot.style.boxShadow = '0 0 8px rgba(192,132,252,0.5)';
                } else {
                    dot.style.background = '#2a2a35';
                    dot.style.boxShadow = 'none';
                }
            }
        }
    }
    
    document.querySelectorAll('[data-key]').forEach(btn => {
        btn.addEventListener('click', () => {
            const key = btn.dataset.key;
            if (key === '⌫') {
                pinInput = pinInput.slice(0, -1);
            } else if (pinInput.length < 4) {
                pinInput += key;
            }
            
            updateDots();
            
            if (pinInput.length === 4) {
                if (pinInput === DEV_PIN) {
                    window.BlankLog.AppState.user = { role: 'admin', tier: 'premium' };
                    window.BlankLog.AppState.isUnlocked = true;
                    window.BlankLog.StorageService.saveAppState();
                    window.BlankLog.renderApp();
                } else if (pinInput === USER_PIN) {
                    window.BlankLog.AppState.user = { role: 'user', tier: 'free' };
                    window.BlankLog.AppState.isUnlocked = true;
                    window.BlankLog.StorageService.saveAppState();
                    window.BlankLog.renderApp();
                } else {
                    document.getElementById('pin-error').innerHTML = '<span class="animate-pulse">❌ Incorrect PIN. Try again.</span>';
                    pinInput = '';
                    updateDots();
                    setTimeout(() => {
                        const errorDiv = document.getElementById('pin-error');
                        if (errorDiv) errorDiv.innerHTML = '';
                    }, 2000);
                }
            }
        });
    });
};

// Override the init function to use new lock screen
const originalInit = window.init;
window.init = function() {
    window.BlankLog.StorageService.loadAppState();
    if (!window.BlankLog.AppState.user) {
        window.BlankLog.AppState.user = { role: 'user', tier: 'free' };
    }
    if (!window.BlankLog.AppState.usage) {
        window.BlankLog.AppState.usage = window.BlankLog.StorageService.getDefaultUsage();
    }
    window.renderLockScreen();
    window.addEventListener('usage-updated', () => {
        if (window.BlankLog.AppState.isUnlocked) window.BlankLog.renderApp();
    });
};

// Re-run init if already loaded
if (typeof window.BlankLog !== 'undefined') {
    window.init();
}
</script>
