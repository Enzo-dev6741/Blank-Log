// ---------- STATISTICS CALCULATIONS ----------
function calculateUserStats() {
    const resolvedPredictions = kalshiState.predictionHistory.filter(p => p.outcome === 'correct' || p.outcome === 'incorrect');
    const correctPredictions = resolvedPredictions.filter(p => p.outcome === 'correct');
    const totalPoints = resolvedPredictions.reduce((sum, p) => sum + (p.pointsEarned || 0), 0);
    const maxPossiblePoints = resolvedPredictions.reduce((sum, p) => sum + p.confidence, 0);
    
    return {
        totalPredictions: kalshiState.activePredictions.length + kalshiState.predictionHistory.length,
        activePredictions: kalshiState.activePredictions.length,
        resolvedPredictions: resolvedPredictions.length,
        accuracy: resolvedPredictions.length > 0 ? (correctPredictions.length / resolvedPredictions.length) * 100 : 0,
        correctCount: correctPredictions.length,
        incorrectCount: resolvedPredictions.length - correctPredictions.length,
        totalPoints: totalPoints,
        maxPossiblePoints: maxPossiblePoints,
        accuracyScore: maxPossiblePoints > 0 ? (totalPoints / maxPossiblePoints) * 100 : 0,
        streak: calculateCurrentStreak()
    };
}

function calculateCurrentStreak() {
    let streak = 0;
    for (let i = 0; i < kalshiState.predictionHistory.length; i++) {
        if (kalshiState.predictionHistory[i].outcome === 'correct') {
            streak++;
        } else if (kalshiState.predictionHistory[i].outcome === 'incorrect') {
            break;
        }
    }
    return streak;
}

