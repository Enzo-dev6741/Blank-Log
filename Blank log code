function generateAnalyticsData() {
    const days = adminState.analyticsTimeRange === '7d' ? 7 : adminState.analyticsTimeRange === '30d' ? 30 : 90;
    const data = [];
    const now = new Date();
    
    for (let i = days - 1; i >= 0; i--) {
        const date = new Date(now);
        date.setDate(date.getDate() - i);
        
        data.push({
            date: date.toISOString().split('T')[0],
            marketing: Math.floor(Math.random() * 200) + 50,
            generator: Math.floor(Math.random() * 180) + 40,
            code: Math.floor(Math.random() * 120) + 20,
            kalshi: Math.floor(Math.random() * 80) + 10,
            activeUsers: Math.floor(Math.random() * 300) + 100
        });
    }
    
    adminState.analyticsData = data;
}

// ---------- SANDBOX EXECUTION ----------
function runSandboxCode() {
    const code = adminState.sandboxCode;
    const language = adminState.sandboxLanguage;
    
    adminState.sandboxOutput = '🚀 Executing sandbox code...\n\n';
    
    setTimeout(() => {
        try {
            // Safe execution simulation (in real app, this would be server-side)
            const simulatedOutput = simulateCodeExecution(code, language);
            adminState.sandboxOutput = simulatedOutput;
            
            // Add to history
            adminState.sandboxHistory.unshift({
                id: Date.now(),
                code: code.substring(0, 200),
                output: simulatedOutput.substring(0, 500),
                language: language,
                timestamp: new Date().toISOString()
            });
            
            if (adminState.sandboxHistory.length > 20) adminState.sandboxHistory.pop();
            
            window.BlankLog.ActivityService.addActivity('generation', 'sandbox', `Executed ${language} code in sandbox`, { language: language });
        } catch (e) {
            adminState.sandboxOutput = `❌ Error: ${e.message}\n\nStack trace:\n${e.stack}`;
        }
        
        updateAdminUI();
    }, 500);
}

function simulateCodeExecution(code, language) {
    const lines = code.split('\n').length;
    const hasFunction = code.includes('function') || code.includes('def');
    const hasLoop = code.includes('for') || code.includes('while');
    
    let output = `=== Sandbox Execution Report ===\n`;
    output += `Language: ${language}\n`;
    output += `Lines executed: ${lines}\n`;
    output += `Execution time: ${Math.floor(Math.random() * 100) + 10}ms\n`;
    output += `Memory used: ${Math.floor(Math.random() * 50) + 10}MB\n\n`;
    
    output += `=== Console Output ===\n`;
    
    if (hasFunction) {
        output += `> Function detected. Simulating execution...\n`;
        output += `> Function executed successfully\n`;
        output += `> Return value: { status: "ok", result: 42, metadata: { sandbox: true } }\n\n`;
    }
    
    if (hasLoop) {
        output += `> Loop iteration detected.\n`;
        output += `> Iterations simulated: ${Math.floor(Math.random() * 100) + 10}\n`;
        output += `> Total operations: ${Math.floor(Math.random() * 1000) + 100}\n\n`;
    }
    
    output += `=== Execution Summary ===\n`;
    output += `✅ No security violations detected\n`;
    output += `✅ No memory leaks detected\n`;
    output += `✅ All operations completed successfully\n`;
    output += `⚠️  Sandbox isolation: Active\n`;
    output += `📊 Performance score: ${Math.floor(Math.random() * 30) + 70}/100\n\n`;
    
    output += `=== Sample Output ===\n`;
    output += `Hello from Blank Log™ Sandbox!\n`;
    output += `Timestamp: ${new Date().toISOString()}\n`;
    output += `Session: ${adminState.sandboxSessionId || 'sbox_' + Math.random().toString(36).substring(2, 10)}\n`;
    
    return output;
}

