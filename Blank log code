function renderAnalyticsCharts() {
    const data = adminState.analyticsData;
    if (!data || !window.Chart) return;
    
    const dates = data.map(d => d.date.slice(5));
    const marketingData = data.map(d => d.marketing);
    const generatorData = data.map(d => d.generator);
    const codeData = data.map(d => d.code);
    const kalshiData = data.map(d => d.kalshi);
    const usersData = data.map(d => d.activeUsers);
    
    // Destroy existing charts
    if (adminState.analyticsCharts.usage) adminState.analyticsCharts.usage.destroy();
    if (adminState.analyticsCharts.users) adminState.analyticsCharts.users.destroy();
    if (adminState.analyticsCharts.distribution) adminState.analyticsCharts.distribution.destroy();
    
    // Usage Trends Chart
    const usageCtx = document.getElementById('usageChart')?.getContext('2d');
    if (usageCtx) {
        adminState.analyticsCharts.usage = new Chart(usageCtx, {
            type: 'line',
            data: {
                labels: dates,
                datasets: [
                    { label: 'Marketing', data: marketingData, borderColor: '#a855f7', backgroundColor: 'rgba(168,85,247,0.1)', tension: 0.4, fill: true },
                    { label: 'Generator', data: generatorData, borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.1)', tension: 0.4, fill: true },
                    { label: 'Code', data: codeData, borderColor: '#10b981', backgroundColor: 'rgba(16,185,129,0.1)', tension: 0.4, fill: true },
                    { label: 'Kalshi', data: kalshiData, borderColor: '#f97316', backgroundColor: 'rgba(249,115,22,0.1)', tension: 0.4, fill: true }
                ]
            },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#9ca3af' } } } }
        });
    }
    
    // Users Chart
    const usersCtx = document.getElementById('usersChart')?.getContext('2d');
    if (usersCtx) {
        adminState.analyticsCharts.users = new Chart(usersCtx, {
            type: 'bar',
            data: {
                labels: dates,
                datasets: [{ label: 'Active Users', data: usersData, backgroundColor: '#06b6d4', borderRadius: 8 }]
            },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#9ca3af' } } } }
        });
    }
    
    // Distribution Chart
    const distCtx = document.getElementById('distributionChart')?.getContext('2d');
    if (distCtx) {
        const totals = [
            data.reduce((s, d) => s + d.marketing, 0),
            data.reduce((s, d) => s + d.generator, 0),
            data.reduce((s, d) => s + d.code, 0),
            data.reduce((s, d) => s + d.kalshi, 0)
        ];
        adminState.analyticsCharts.distribution = new Chart(distCtx, {
            type: 'doughnut',
            data: {
                labels: ['Marketing', 'Generator', 'Code', 'Kalshi'],
                datasets: [{ data: totals, backgroundColor: ['#a855f7', '#3b82f6', '#10b981', '#f97316'], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#9ca3af' } } } }
        });
    }
}

