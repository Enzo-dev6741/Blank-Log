function generateCodeIssues(code, language) {
    const issues = [];
    if (code.includes('console.log') || code.includes('print')) {
        issues.push('• ⚠️ Debug statements left in production code');
    }
    if (!code.includes('try') && (code.includes('error') || code.includes('throw'))) {
        issues.push('• ❌ Missing error handling for potential exceptions');
    }
    if (code.split('\n').some(line => line.length > 120)) {
        issues.push('• 📏 Lines exceed 120 characters (reduces readability)');
    }
    if (code.match(/function\s+\w+\s*\([^)]*\)/g)?.some(f => f.length > 80)) {
        issues.push('• 🔧 Functions with too many parameters (consider using object params)');
    }
    if (!code.includes('return') && code.includes('function')) {
        issues.push('• 🔄 Functions missing explicit return statements');
    }
    if (issues.length === 0) {
        issues.push('• ✅ No major issues detected');
        issues.push('• 💡 Minor improvements possible (see recommendations)');
    }
    return issues.join('\n');
}

function generateSecurityConcerns(code) {
    const concerns = [];
    if (code.includes('eval(')) {
        concerns.push('• 🔴 CRITICAL: eval() usage (security risk)');
    }
    if (code.includes('innerHTML') || code.includes('document.write')) {
        concerns.push('• 🟡 XSS vulnerability potential');
    }
    if (code.includes('password') || code.includes('secret') || code.includes('key')) {
        concerns.push('• 🔴 Hardcoded credentials detected');
    }
    if (concerns.length === 0) {
        concerns.push('• ✅ No obvious security vulnerabilities');
        concerns.push('• 💡 Consider adding input validation');
    }
    return concerns.join('\n');
}

function generatePerformanceTips(code) {
    const tips = [];
    if (code.includes('for') && code.match(/for\s*\([^)]*\)/g)?.length > 3) {
        tips.push('• Consider replacing nested loops with optimized algorithms');
    }
    if (code.includes('console.log') && code.match(/console\.log/g)?.length > 5) {
        tips.push('• Remove debug logs in production for better performance');
    }
    tips.push('• Cache repeated calculations for better efficiency');
    return tips.join('\n');
}

function generateBestPractices(language) {
    const practices = {
        javascript: '• Use const/let instead of var\n• Implement async/await for promises\n• Add JSDoc comments',
        python: '• Follow PEP 8 style guide\n• Use type hints\n• Implement context managers',
        default: '• Add comprehensive comments\n• Follow language conventions\n• Write unit tests'
    };
    return practices[language] || practices.default;
}

function detectCodePurpose(code) {
    if (code.includes('fetch') || code.includes('axios') || code.includes('request')) return 'API communication';
    if (code.includes('sort') || code.includes('filter') || code.includes('map')) return 'data transformation';
    if (code.includes('render') || code.includes('component')) return 'UI rendering';
    if (code.includes('database') || code.includes('query')) return 'data persistence';
    return 'general purpose computation';
}

function generateExplanation(code, language) {
    return `**Main Functionality:** ${detectCodePurpose(code)}

**Control Flow:**
${code.includes('if') ? '• Conditional branches present' : '• Linear execution path'}
${code.includes('for') || code.includes('while') ? '• Loops for iteration' : '• No iterative patterns'}
${code.includes('function') ? '• Modular function design' : '• Procedural approach'}

**Data Flow:**
Input → Processing → Output

**Dependencies:**
${code.includes('require') || code.includes('import') ? '• External modules imported' : '• Pure implementation'}`;
}

function generateImprovementTips(code) {
    const tips = [];
    if (!code.includes('comment') && !code.includes('//') && !code.includes('/*')) {
        tips.push('Add documentation comments');
    }
    if (code.length < 200) {
        tips.push('Consider adding more functionality');
    }
    tips.push('Extract magic numbers into constants');
    tips.push('Add input validation for robustness');
    return tips.join('\n');
}

function generateCriticalBugs(code) {
    const bugs = [];
    if (code.includes('==') && !code.includes('===')) {
        bugs.push('• Loose equality (==) may cause type coercion bugs');
    }
    if (code.includes('undefined') && !code.includes('typeof')) {
        bugs.push('• Potential undefined reference errors');
    }
    if (bugs.length === 0) {
        bugs.push('• No critical bugs detected in static analysis');
    }
    return bugs.join('\n');
}

function generateEdgeCases(code) {
    return `• Empty input handling
• Null/undefined values
• Large data sets
• Concurrent access
• Resource exhaustion`;
}

function generateRewrittenCode(code, language) {
    // Simple code transformation for demo
    let rewritten = code;
    rewritten = rewritten.replace(/var /g, language === 'javascript' ? 'const ' : '');
    rewritten = rewritten.replace(/console\.log/g, '// console.log (commented for production)');
    if (!rewritten.includes('try')) {
        rewritten = `try {\n${rewritten}\n} catch (error) {\n  console.error('Error:', error);\n  throw error;\n}`;
    }
    return rewritten;
}

function generateDebuggedCode(code, language) {
    let debugged = code;
    if (!debugged.includes('try')) {
        debugged = `try {\n${debugged}\n} catch (error) {\n  console.error('Handled error:', error);\n  return null;\n}`;
    }
    debugged = debugged.replace(/console\.log/g, 'logger.debug');
    return debugged;
}

function generateDocumentation(code, language) {
    const lines = code.split('\n');
    const functionNames = code.match(/function\s+(\w+)/g) || [];
    
    let docs = `/**
 * ${language.toUpperCase()} Module Documentation
 * @module ${language}_module
 */\n\n`;
    
    functionNames.forEach(fn => {
        const name = fn.replace('function ', '');
        docs += `/**
 * ${name} - Core functionality
 * @param {*} input - Input parameter
 * @returns {*} Processed result
 */\n${fn}() {\n  // Implementation\n}\n\n`;
    });
    
    return docs + code;
}

function generateTests(code, language) {
    if (language === 'javascript') {
        return `describe('Code Tests', () => {
  test('should handle valid input', () => {
    const result = main('test');
    expect(result).toBeDefined();
  });
  
  test('should handle edge cases', () => {
    expect(() => main(null)).not.toThrow();
  });
  
  test('should return expected output', () => {
    const expected = true;
    const actual = main('valid');
    expect(actual).toBe(expected);
  });
});`;
    } else {
        return `import pytest

def test_main_valid_input():
    result = main("test")
    assert result is not None

def test_main_edge_cases():
    try:
        main(None)
    except Exception as e:
        pytest.fail(f"Edge case failed: {e}")

def test_main_output():
    expected = True
    actual = main("valid")
    assert actual == expected`;
    }
}

