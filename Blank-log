function createNewChatSession() {
    const session = {
        id: Date.now(),
        title: "New Conversation",
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString(),
        messageCount: 0
    };
    chatState.sessions.unshift(session);
    chatState.currentSessionId = session.id;
    chatState.messages = [];
    StorageService.saveAppState();
    updateChatUI();
    return session;
}

function loadChatSession(sessionId) {
    const session = chatState.sessions.find(s => s.id === sessionId);
    if (session) {
        chatState.currentSessionId = sessionId;
        // Load messages from storage
        const savedMessages = StorageService.load(`chat_messages_${sessionId}`, []);
        chatState.messages = savedMessages;
        updateChatUI();
    }
}

function sendChatMessage() {
    if (!chatState.inputMessage.trim()) return;
    
    if (!CreditManager.canUse('chat')) {
        alert(`You've used all your chat credits for this month. ${AppState.user.plan === 'free' ? 'Upgrade to Premium or Pro for more messages!' : 'Wait for the monthly reset.'}`);
        return;
    }
    
    // Add user message
    const userMessage = {
        id: Date.now(),
        role: 'user',
        content: chatState.inputMessage,
        timestamp: new Date().toISOString()
    };
    chatState.messages.push(userMessage);
    
    // Update session title if first message
    if (chatState.messages.length === 1 && chatState.currentSessionId) {
        const session = chatState.sessions.find(s => s.id === chatState.currentSessionId);
        if (session && session.title === "New Conversation") {
            session.title = chatState.inputMessage.substring(0, 40) + (chatState.inputMessage.length > 40 ? '...' : '');
        }
    }
    
    const userInput = chatState.inputMessage;
    chatState.inputMessage = '';
    chatState.isTyping = true;
    updateChatUI();
    
    // Simulate AI response after delay
    setTimeout(() => {
        const aiResponse = generateAIResponse(userInput);
        const assistantMessage = {
            id: Date.now(),
            role: 'assistant',
            content: aiResponse,
            timestamp: new Date().toISOString()
        };
        chatState.messages.push(assistantMessage);
        chatState.isTyping = false;
        
        // Update session info
        if (chatState.currentSessionId) {
            const session = chatState.sessions.find(s => s.id === chatState.currentSessionId);
            if (session) {
                session.updatedAt = new Date().toISOString();
                session.messageCount = chatState.messages.length;
            }
        }
        
        // Save messages to storage
        StorageService.save(`chat_messages_${chatState.currentSessionId}`, chatState.messages);
        StorageService.saveAppState();
        
        // Use credits
        CreditManager.useCredits('chat');
        UpgradeManager.addActivity('generation', `Chat message sent to AI assistant`);
        
        updateChatUI();
    }, 1000);
}

function deleteChatSession(sessionId) {
    chatState.sessions = chatState.sessions.filter(s => s.id !== sessionId);
    StorageService.save(`chat_messages_${sessionId}`, null);
    if (chatState.currentSessionId === sessionId) {
        if (chatState.sessions.length > 0) {
            loadChatSession(chatState.sessions[0].id);
        } else {
            createNewChatSession();
        }
    }
    StorageService.saveAppState();
    updateChatUI();
}

function formatChatTimestamp(timestamp) {
    const date = new Date(timestamp);
    const now = new Date();
    const diffHours = (now - date) / (1000 * 60 * 60);
    
    if (diffHours < 24) {
        return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    } else if (diffHours < 48) {
        return 'Yesterday';
    } else {
        return date.toLocaleDateString();
    }
}

