// ---------- MAIN APP RENDER ----------
function renderMainApp() {
    const root = document.getElementById('root');
    
    let tabContent = '';
    switch(AppState.activeTab) {
        case 'home': tabContent = renderHomeTab(); break;
        case 'marketing': tabContent = renderMarketingTab(); break;
        case 'chat': tabContent = renderChatTab(); break;
        case 'kalshi': tabContent = renderKalshiTab(); break;
        case 'code': tabContent = renderCodeTab(); break;
        case 'admin': tabContent = renderAdminTab(); break;
        default: tabContent = renderHomeTab();
    }
    
    root.innerHTML = `
        <div class="min-h-screen bg-[#0a0a0f]">
            ${renderSidebar()}
            ${renderMobileNav()}
            <main class="main-content lg:ml-64 min-h-screen">
                <div class="p-4 md:p-8 pb-24 md:pb-8">
                    ${tabContent}
                </div>
            </main>
        </div>
    `;
}

function renderApp() {
    if (!AppState.isUnlocked) {
        renderLockScreen();
    } else {
        renderMainApp();
    }
}

// ---------- GLOBAL FUNCTIONS ----------
window.setActiveTab = function(tabId) {
    AppState.activeTab = tabId;
    StorageService.saveAppState();
    renderMainApp();
    setTimeout(() => {
        if (window.loadTabContent) window.loadTabContent(tabId);
    }, 50);
};

