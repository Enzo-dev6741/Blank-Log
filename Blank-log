    const isAdmin = AppState.user.role === 'admin' || AppState.user.role === 'developer';
    if (!isAdmin) {
        container.innerHTML = `<div class="bg-red-500/10 rounded-xl p-12 text-center border border-red-500/20"><div class="text-6xl mb-4">🔒</div><h2 class="text-2xl font-bold text-white">Access Denied</h2><p class="text-gray-400 mt-2">Admin access only</p></div>`;
        return;
    }
    
    let content = '';
    switch(adminState.activeSubtab) {
        case 'dashboard': content = renderAdminDashboard(); break;
        case 'users': content = renderAdminUsers(); break;
        case 'logs': content = renderAdminLogs(); break;
        case 'sandbox': content = renderAdminSandbox(); break;
        case 'settings': content = renderAdminSettings(); break;
        default: content = renderAdminDashboard();
    }
    
    container.innerHTML = `
        <div class="space-y-6">
            <div class="flex flex-wrap gap-2 border-b border-white/10 pb-4">
                ${adminSubtabs.map(tab => `
                    <button onclick="setAdminSubtab('${tab.id}')" 
                        class="px-4 py-2 rounded-lg transition-all flex items-center gap-2 ${adminState.activeSubtab === tab.id ? 'bg-purple-600 text-white' : 'bg-[#12121a] text-gray-400 hover:text-white'}">
                        <span>${tab.icon}</span>
                        <span>${tab.label}</span>
                    </button>
                `).join('')}
            </div>
            ${content}
        </div>
    `;
}

function renderAdminDashboard() {
    const totalUsers = adminState.users.length;
    const activeUsers = adminState.users.filter(u => u.status === 'active').length;
    const premiumUsers = adminState.users.filter(u => u.plan !== 'free').length;
    const totalUsage = adminState.users.reduce((sum, u) => sum + Object.values(u.usage).reduce((a,b) => a+b, 0), 0);
    
    return `
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-[#12121a] rounded-xl p-4 border border-white/10"><p class="text-gray-500 text-sm">Total Users</p><p class="text-2xl font-bold text-white">${totalUsers}</p></div>
            <div class="bg-[#12121a] rounded-xl p-4 border border-white/10"><p class="text-gray-500 text-sm">Active Users</p><p class="text-2xl font-bold text-white">${activeUsers}</p></div>
            <div class="bg-[#12121a] rounded-xl p-4 border border-white/10"><p class="text-gray-500 text-sm">Premium Users</p><p class="text-2xl font-bold text-white">${premiumUsers}</p></div>
            <div class="bg-[#12121a] rounded-xl p-4 border border-white/10"><p class="text-gray-500 text-sm">Total Usage</p><p class="text-2xl font-bold text-white">${totalUsage.toLocaleString()}</p></div>
        </div>
    `;
}

function renderAdminUsers() {
    const filteredUsers = adminState.users.filter(u => u.username.includes(adminState.userSearch));
    
    return `
        <div class="bg-[#12121a] rounded-xl border border-white/10 overflow-hidden">
            <div class="p-4 border-b border-white/10"><input type="text" id="admin-user-search" placeholder="Search users..." class="w-full px-3 py-2 bg-[#0f0f15] border border-white/10 rounded-lg text-white"></div>
            <div class="overflow-x-auto">
                <table class="w-full"><thead class="bg-[#0f0f15]"><tr><th class="p-3 text-left text-xs text-gray-400">User</th><th class="p-3 text-left text-xs text-gray-400">Role</th><th class="p-3 text-left text-xs text-gray-400">Plan</th><th class="p-3 text-left text-xs text-gray-400">Status</th></tr></thead>
                <tbody>${filteredUsers.map(u => `<tr class="border-t border-white/5"><td class="p-3"><p class="text-sm text-white">${u.username}</p></td><td class="p-3"><span class="text-xs px-2 py-1 rounded ${u.role === 'admin' ? 'bg-purple-500/20 text-purple-400' : u.role === 'developer' ? 'bg-blue-500/20 text-blue-400' : 'bg-gray-500/20 text-gray-400'}">${u.role}</span></td><td class="p-3"><span class="text-xs px-2 py-1 rounded ${u.plan === 'pro' ? 'bg-orange-500/20 text-orange-400' : u.plan === 'premium' ? 'bg-purple-500/20 text-purple-400' : 'bg-gray-500/20 text-gray-400'}">${u.plan}</span></td><td class="p-3"><span class="text-xs px-2 py-1 rounded ${u.status === 'active' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}">${u.status}</span></td></tr>`).join('')}</tbody>
                </table>
            </div>
        </div>
    `;
}

function renderAdminLogs() {
    const filteredLogs = adminState.systemLogs.filter(l => adminState.logFilter === 'all' || l.level === adminState.logFilter);
    
    return `
        <div class="bg-[#12121a] rounded-xl border border-white/10">
            <div class="p-4 border-b border-white/10 flex gap-2"><button onclick="adminState.logFilter='all'; updateAdminUI()" class="px-3 py-1 rounded text-sm ${adminState.logFilter === 'all' ? 'bg-purple-600' : 'bg-[#0f0f15]'}">All</button><button onclick="adminState.logFilter='info'; updateAdminUI()" class="px-3 py-1 rounded text-sm">Info</button><button onclick="adminState.logFilter='warning'; updateAdminUI()" class="px-3 py-1 rounded text-sm">Warning</button></div>
            <div class="divide-y divide-white/5 max-h-[400px] overflow-y-auto">${filteredLogs.map(log => `<div class="p-3"><div class="flex items-center gap-2"><span class="text-lg">${log.level === 'error' ? '❌' : log.level === 'warning' ? '⚠️' : 'ℹ️'}</span><span class="text-sm text-gray-300">${log.message}</span><span class="text-xs text-gray-500 ml-auto">${new Date(log.timestamp).toLocaleTimeString()}</span></div></div>`).join('')}</div>
        </div>
    `;
}

function renderAdminSandbox() {
    return `
        <div class="grid lg:grid-cols-2 gap-6">
            <div class="bg-[#12121a] rounded-xl p-5 border border-white/10"><textarea id="sandbox-code" rows="15" class="w-full px-4 py-3 bg-[#0f0f15] border border-white/10 rounded-lg text-gray-300 font-mono text-sm">${adminState.sandboxCode.replace(/"/g, '&quot;')}</textarea><button onclick="runSandbox()" class="w-full mt-3 py-2 bg-purple-600 hover:bg-purple-700 rounded-lg">▶ Run Code</button></div>
            <div class="bg-[#12121a] rounded-xl p-5 border border-white/10"><h3 class="font-semibold text-white mb-3">Output</h3><pre class="bg-black/30 rounded-lg p-4 text-gray-300 font-mono text-sm min-h-[300px] whitespace-pre-wrap">${adminState.sandboxOutput || '// Output will appear here'}</pre></div>
        </div>
    `;
}

function renderAdminSettings() {
    return `
        <div class="bg-[#12121a] rounded-xl p-5 border border-white/10">
            <h3 class="text-lg font-semibold text-white mb-4">System Settings</h3>
            <div class="space-y-4"><div class="flex justify-between items-center"><span class="text-gray-400">Maintenance Mode</span><button class="px-3 py-1 bg-red-500/20 text-red-400 rounded">Disable</button></div><div class="flex justify-between items-center"><span class="text-gray-400">Clear All Cache</span><button class="px-3 py-1 bg-yellow-500/20 text-yellow-400 rounded" onclick="localStorage.clear(); location.reload();">Clear Cache</button></div><div class="flex justify-between items-center"><span class="text-gray-400">Export Analytics</span><button class="px-3 py-1 bg-green-500/20 text-green-400 rounded">Export CSV</button></div></div>
        </div>
    `;
}

function setAdminSubtab(subtab) { adminState.activeSubtab = subtab; updateAdminUI(); }

// Override render functions
function renderCodeTab() { return `<div id="code-full-content" class="fade-in"></div>`; }
function renderAdminTab() { return `<div id="admin-full-content" class="fade-in"></div>`; }

function initCodeTab() { loadCodeHistory(); updateCodeUI(); }
function initAdminTab() { initAdminData(); updateAdminUI(); }

// Update tab loader
const chunk4Loader = window.loadTabContent;
window.loadTabContent = function(tabId) {
    if (chunk4Loader) chunk4Loader(tabId);
    if (tabId === 'code') initCodeTab();
    if (tabId === 'admin') initAdminTab();
};

// Exports
window.processCodeTask = processCodeTask;
window.loadCodeHistoryItem = loadCodeHistoryItem;
window.setAdminSubtab = setAdminSubtab;
window.runSandbox = runSandbox;

// ============================================================
// END OF CHUNK 4
// ============================================================
</script>
