            exports: false,
            advanced: false
        }
    },
    premium: {
        name: 'Premium',
        price: 10,
        priceDisplay: '$10/mo',
        credits: {
            marketing: 500,
            chat: 2000,
            kalshi: 300,
            code: 400
        },
        features: {
            marketing: '500 auto-posts/month',
            chat: '2,000 AI messages/month',
            kalshi: '300 predictions/month',
            code: '400 code tasks/month',
