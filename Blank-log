</head>
<body class="bg-[#0a0a0f] text-gray-200">

<div id="root"></div>

<script>
// ============================================================
// BLANK LOG™ — CHUNK 1: CORE ARCHITECTURE
// ============================================================
// Pricing: Free ($0), Premium ($10/mo), Pro ($25/mo)
// Trials: Premium = 2 days, Pro = 1 day
// ============================================================

// ---------- PRICING AND PLAN DEFINITIONS ----------
const PLANS = {
    free: {
        name: 'Free',
        price: 0,
        priceDisplay: '$0',
        credits: {
            marketing: 30,
            chat: 50,
            kalshi: 20,
