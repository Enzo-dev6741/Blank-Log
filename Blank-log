function renderMarketingTab() { return `<div class="fade-in text-center py-20"><div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-purple-500 border-t-transparent"></div><p class="mt-4 text-gray-400">Loading Marketing Workspace...</p></div>`; }
function renderChatTab() { return `<div class="fade-in text-center py-20"><div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-purple-500 border-t-transparent"></div><p class="mt-4 text-gray-400">Loading AI Chat...</p></div>`; }
function renderKalshiTab() { return `<div class="fade-in text-center py-20"><div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-purple-500 border-t-transparent"></div><p class="mt-4 text-gray-400">Loading Kalshi Intelligence...</p></div>`; }
