function createPrediction() {
    if (!CreditManager.canUse('kalshi')) {
        alert(`You've used all your prediction credits for this month. ${AppState.user.plan === 'free' ? 'Upgrade to Premium or Pro for more predictions!' : 'Wait for the monthly reset.'}`);
        return;
    }
    
    if (!kalshiState.currentPrediction.title.trim()) {
        alert('Please enter a prediction title');
        return;
    }
    
    kalshiState.isGenerating = true;
    updateKalshiUI();
    
    setTimeout(() => {
        const analysis = generatePredictionAnalysis(
            kalshiState.currentPrediction.title,
            kalshiState.currentPrediction.category,
            kalshiState.currentPrediction.confidence
        );
        
        const newPrediction = {
            id: Date.now(),
            title: kalshiState.currentPrediction.title,
            description: kalshiState.currentPrediction.description,
            category: kalshiState.currentPrediction.category,
            confidence: kalshiState.currentPrediction.confidence,
            timeframe: kalshiState.currentPrediction.timeframe,
            createdAt: new Date().toISOString(),
            status: "active",
            outcome: null,
            analysis: analysis
        };
        
        AppState.predictions.unshift(newPrediction);
        StorageService.saveAppState();
        
        CreditManager.useCredits('kalshi');
        UpgradeManager.addActivity('generation', `Created prediction: "${kalshiState.currentPrediction.title.substring(0, 40)}..."`);
        
        // Reset form
        kalshiState.currentPrediction = {
            title: '',
            category: 'technology',
            confidence: 75,
            timeframe: '7d',
            description: ''
        };
        
        kalshiState.isGenerating = false;
        updateKalshiUI();
        showToastKalshi('Prediction created!', 'success');
    }, 1500);
}

function generatePredictionAnalysis(title, category, confidence) {
    const analyses = [
        `Based on current market data and historical patterns, this prediction shows ${confidence}% confidence. Key indicators suggest ${confidence > 70 ? 'strong' : 'moderate'} momentum in the ${category} sector.`,
        `AI Analysis: Multiple data points support this prediction. The ${category} market is showing ${confidence > 80 ? 'bullish' : confidence > 50 ? 'neutral' : 'bearish'} signals.`,
        `Market intelligence indicates ${confidence}% probability. Key factors: technical indicators ${confidence > 70 ? 'align' : 'show mixed signals'}, volume patterns confirm momentum.`
    ];
    return analyses[Math.floor(Math.random() * analyses.length)];
}

function resolvePrediction(predictionId, outcome) {
    const prediction = AppState.predictions.find(p => p.id === predictionId);
    if (prediction && (AppState.user.role === 'admin' || AppState.user.role === 'developer')) {
        prediction.status = 'resolved';
        prediction.outcome = outcome;
        prediction.resolvedAt = new Date().toISOString();
        prediction.pointsEarned = outcome === 'correct' ? prediction.confidence : 0;
        
        AppState.predictionHistory.unshift(prediction);
        AppState.predictions = AppState.predictions.filter(p => p.id !== predictionId);
        StorageService.saveAppState();
        updateKalshiUI();
        showToastKalshi(`Prediction marked as ${outcome}!`, outcome === 'correct' ? 'success' : 'error');
    }
}

function deletePrediction(predictionId) {
    AppState.predictions = AppState.predictions.filter(p => p.id !== predictionId);
    StorageService.saveAppState();
    updateKalshiUI();
    showToastKalshi('Prediction deleted', 'info');
}

function calculateKalshiStats() {
    const totalPredictions = AppState.predictions.length + AppState.predictionHistory.length;
    const activePredictions = AppState.predictions.length;
    const resolvedPredictions = AppState.predictionHistory.filter(p => p.outcome === 'correct' || p.outcome === 'incorrect');
    const correctPredictions = resolvedPredictions.filter(p => p.outcome === 'correct');
    const accuracy = resolvedPredictions.length > 0 ? (correctPredictions.length / resolvedPredictions.length) * 100 : 0;
    const totalPoints = resolvedPredictions.reduce((sum, p) => sum + (p.pointsEarned || 0), 0);
    
    return { totalPredictions, activePredictions, resolvedPredictions: resolvedPredictions.length, accuracy, correctCount: correctPredictions.length, totalPoints };
}

function showToastKalshi(message, type = 'info') {
    const toast = document.createElement('div');
    toast.className = `fixed bottom-20 right-4 ${type === 'success' ? 'bg-green-500/90' : type === 'error' ? 'bg-red-500/90' : 'bg-purple-500/90'} text-white px-4 py-2 rounded-lg shadow-lg fade-in z-50`;
    toast.innerHTML = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

