            exports: true,
            advanced: 'Basic advanced features'
        }
    },
    pro: {
        name: 'Pro',
        price: 25,
        priceDisplay: '$25/mo',
        credits: {
            marketing: 5000,
            chat: 20000,
            kalshi: 3000,
            code: 5000
        },
        features: {
            marketing: '5,000 auto-posts/month',
            chat: '20,000 AI messages/month',
            kalshi: '3,000 predictions/month',
            code: '5,000 code tasks/month',
            history: 'Unlimited retention',
            exports: true,
            advanced: 'Full advanced features + API'
        }
    }
};

// ---------- APP STATE ----------
const AppState = {
    // Lock status
    isUnlocked: false,
    
    // User data
    user: {
        role: 'user',  // 'user', 'admin', 'developer'
        plan: 'free',   // 'free', 'premium', 'pro'
        trialActive: false,
        trialType: null,
        trialEnds: null
    },
    
    // Active tab
    activeTab: 'home',
    
    // Credit usage (tracks used this month)
    usage: {
        marketing: 0,
        chat: 0,
        kalshi: 0,
        code: 0,
        lastReset: new Date().toISOString()
    },
    
    // Content stores
    marketingDrafts: [],
    scheduledPosts: [],
    chatSessions: [],
    chatMessages: [],
    predictions: [],
    predictionHistory: [],
    codeHistory: [],
    
    // Admin data
    adminUsers: [],
    systemLogs: [],
    adminSettings: {
        marketingPrice: 10,
        chatPrice: 10,
        kalshiPrice: 10,
        codePrice: 10
    },
    
    // Activity feed
    activityFeed: []
};

// ---------- STORAGE SERVICE ----------
const StorageService = {
    save(key, data) {
        try {
            localStorage.setItem(`blanklog_${key}`, JSON.stringify(data));
            return true;
        } catch(e) { return false; }
    },
    
    load(key, defaultValue = null) {
        try {
            const item = localStorage.getItem(`blanklog_${key}`);
            return item ? JSON.parse(item) : defaultValue;
        } catch(e) { return defaultValue; }
    },
    
    saveAppState() {
        this.save('appState', {
            isUnlocked: AppState.isUnlocked,
            user: AppState.user,
            usage: AppState.usage,
            marketingDrafts: AppState.marketingDrafts,
            scheduledPosts: AppState.scheduledPosts,
            chatSessions: AppState.chatSessions,
            chatMessages: AppState.chatMessages,
            predictions: AppState.predictions,
            predictionHistory: AppState.predictionHistory,
            codeHistory: AppState.codeHistory,
            activityFeed: AppState.activityFeed
        });
    },
    
    loadAppState() {
        const saved = this.load('appState');
        if (saved) {
            AppState.isUnlocked = saved.isUnlocked || false;
            AppState.user = saved.user || { role: 'user', plan: 'free', trialActive: false };
            AppState.usage = saved.usage || this.getDefaultUsage();
            AppState.marketingDrafts = saved.marketingDrafts || [];
            AppState.scheduledPosts = saved.scheduledPosts || [];
            AppState.chatSessions = saved.chatSessions || [];
            AppState.chatMessages = saved.chatMessages || [];
            AppState.predictions = saved.predictions || [];
            AppState.predictionHistory = saved.predictionHistory || [];
            AppState.codeHistory = saved.codeHistory || [];
            AppState.activityFeed = saved.activityFeed || [];
        }
        
        // Check and reset usage monthly
        this.checkMonthlyReset();
    },
    
    getDefaultUsage() {
        return {
            marketing: 0,
            chat: 0,
            kalshi: 0,
            code: 0,
            lastReset: new Date().toISOString()
        };
    },
    
    checkMonthlyReset() {
        const now = new Date();
        const lastReset = new Date(AppState.usage.lastReset);
        
        if (now.getMonth() !== lastReset.getMonth() || now.getFullYear() !== lastReset.getFullYear()) {
            // Reset usage for new month
            AppState.usage = {
                marketing: 0,
                chat: 0,
                kalshi: 0,
                code: 0,
                lastReset: now.toISOString()
            };
            this.saveAppState();
        }
    }
};

// ---------- CREDIT / QUOTA MANAGER ----------
const CreditManager = {
    getRemaining(module) {
        const plan = AppState.user.plan;
        const limit = PLANS[plan].credits[module];
        const used = AppState.usage[module];
        return Math.max(0, limit - used);
    },
    
    getUsed(module) {
        return AppState.usage[module];
    },
    
    getLimit(module) {
        return PLANS[AppState.user.plan].credits[module];
    },
    
    getPercentUsed(module) {
        const limit = this.getLimit(module);
        const used = this.getUsed(module);
        if (limit === 0) return 0;
        return (used / limit) * 100;
    },
    
    canUse(module, amount = 1) {
        const remaining = this.getRemaining(module);
        return remaining >= amount;
    },
    
    useCredits(module, amount = 1) {
        if (!this.canUse(module, amount)) {
            return false;
        }
        AppState.usage[module] += amount;
        StorageService.saveAppState();
        this.dispatchUpdate();
        return true;
    },
    
    getResetInfo() {
        const lastReset = new Date(AppState.usage.lastReset);
        const nextReset = new Date(lastReset);
        nextReset.setMonth(nextReset.getMonth() + 1);
        nextReset.setDate(1);
        const daysLeft = Math.ceil((nextReset - new Date()) / (1000 * 60 * 60 * 24));
        return {
            daysLeft,
            nextResetDate: nextReset.toLocaleDateString()
        };
    },
    
    dispatchUpdate() {
        window.dispatchEvent(new CustomEvent('credits-updated'));
    }
};

// ---------- TRIAL MANAGER ----------
const TrialManager = {
    startTrial(planType) {
        if (planType === 'premium') {
            AppState.user.trialActive = true;
            AppState.user.trialType = 'premium';
            const ends = new Date();
            ends.setDate(ends.getDate() + 2); // 2 days trial
            AppState.user.trialEnds = ends.toISOString();
            AppState.user.plan = 'premium';
        } else if (planType === 'pro') {
            AppState.user.trialActive = true;
            AppState.user.trialType = 'pro';
            const ends = new Date();
            ends.setDate(ends.getDate() + 1); // 1 day trial
            AppState.user.trialEnds = ends.toISOString();
            AppState.user.plan = 'pro';
        }
        StorageService.saveAppState();
        this.dispatchUpdate();
        return true;
    },
    
    checkTrialExpired() {
        if (!AppState.user.trialActive) return false;
        
        const now = new Date();
        const ends = new Date(AppState.user.trialEnds);
        
        if (now >= ends) {
            AppState.user.trialActive = false;
            AppState.user.trialType = null;
            AppState.user.trialEnds = null;
            AppState.user.plan = 'free';
            StorageService.saveAppState();
            this.dispatchUpdate();
            return true;
        }
        return false;
    },
    
    getTrialRemaining() {
        if (!AppState.user.trialActive) return null;
        const ends = new Date(AppState.user.trialEnds);
        const now = new Date();
        const hoursLeft = Math.ceil((ends - now) / (1000 * 60 * 60));
        return hoursLeft;
    },
    
    dispatchUpdate() {
        window.dispatchEvent(new CustomEvent('trial-updated'));
    }
};

// ---------- UPGRADE MANAGER ----------
const UpgradeManager = {
    upgradeToPremium() {
        AppState.user.plan = 'premium';
        AppState.user.trialActive = false;
        AppState.user.trialType = null;
        StorageService.saveAppState();
        this.addActivity('upgrade', 'Upgraded to Premium plan');
        this.dispatchUpdate();
    },
    
    upgradeToPro() {
        AppState.user.plan = 'pro';
        AppState.user.trialActive = false;
        AppState.user.trialType = null;
        StorageService.saveAppState();
        this.addActivity('upgrade', 'Upgraded to Pro plan');
        this.dispatchUpdate();
    },
    
    addActivity(type, message) {
        AppState.activityFeed.unshift({
            id: Date.now(),
            type,
            message,
            timestamp: new Date().toISOString(),
            formattedTime: new Date().toLocaleTimeString()
        });
        if (AppState.activityFeed.length > 100) AppState.activityFeed.pop();
        StorageService.saveAppState();
    },
    
    dispatchUpdate() {
        window.dispatchEvent(new CustomEvent('plan-updated'));
    }
};

// ---------- LOCK SCREEN ----------
let pinInput = '';
const DEMO_PIN = '2024';

function renderLockScreen() {
    const root = document.getElementById('root');
    root.innerHTML = `
        <div class="min-h-screen flex items-center justify-center p-4" style="background: radial-gradient(ellipse at 20% 30%, #0f0f1a, #050508);">
            <div class="w-full max-w-md">
                <div class="text-center mb-12 fade-in">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-purple-500 to-indigo-600 shadow-2xl mb-6">
                        <span class="text-4xl font-black text-white">◼</span>
                    </div>
                    <h1 class="text-4xl font-bold bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent">Blank Log™</h1>
                    <p class="text-gray-500 mt-2">Enter PIN to continue</p>
                </div>
                
                <div class="flex justify-center gap-4 mb-8">
                    ${[0,1,2,3].map(i => `<div class="pin-dot ${pinInput.length > i ? 'filled' : ''}" id="pin-dot-${i}"></div>`).join('')}
                </div>
                
                <div id="pin-error" class="text-center mb-4 text-red-400 text-sm min-h-[40px]"></div>
                
                <div class="grid grid-cols-3 gap-4 max-w-xs mx-auto">
                    ${[1,2,3,4,5,6,7,8,9,'',0,'⌫'].map(key => {
                        if (key === '') return '<div></div>';
                        return `<button class="keypad-btn w-full aspect-square rounded-2xl text-2xl font-semibold ${key === '⌫' ? 'text-purple-400' : 'text-gray-200'} bg-[#1a1a24] hover:bg-[#252530] transition-all" data-key="${key}">${key}</button>`;
                    }).join('')}
                </div>
                
                <div class="text-center mt-8">
                    <p class="text-xs text-gray-600">Demo PIN: <span class="text-purple-400 font-mono">2024</span></p>
                </div>
            </div>
        </div>
    `;
    
    document.querySelectorAll('[data-key]').forEach(btn => {
        btn.addEventListener('click', () => {
            const key = btn.dataset.key;
            if (key === '⌫') {
                pinInput = pinInput.slice(0, -1);
            } else if (pinInput.length < 4) {
                pinInput += key;
            }
            
            for (let i = 0; i < 4; i++) {
                const dot = document.getElementById(`pin-dot-${i}`);
                if (dot) {
                    if (pinInput.length > i) dot.classList.add('filled');
                    else dot.classList.remove('filled');
                }
            }
            
            if (pinInput.length === 4) {
                if (pinInput === DEMO_PIN) {
                    AppState.isUnlocked = true;
                    StorageService.saveAppState();
                    renderApp();
                } else {
                    document.getElementById('pin-error').innerHTML = '<span class="animate-pulse">❌ Incorrect PIN. Try again.</span>';
                    pinInput = '';
                    for (let i = 0; i < 4; i++) {
                        const dot = document.getElementById(`pin-dot-${i}`);
                        if (dot) dot.classList.remove('filled');
                    }
                    setTimeout(() => {
                        const errorDiv = document.getElementById('pin-error');
                        if (errorDiv) errorDiv.innerHTML = '';
                    }, 2000);
                }
            }
        });
    });
}

// ---------- NAVIGATION TABS ----------
const tabs = [
